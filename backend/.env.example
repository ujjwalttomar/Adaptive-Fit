PORT=4000
MONGODB_URI=
JWT_SECRET=
JWT_EXPIRES_IN=7d
NODE_ENV=development
# Page origin shown in the browser — your Vercel URL. Never set this to your API URL
# (e.g. do NOT use *.onrender.com here). Trailing slashes are trimmed automatically.
FRONTEND_URL=http://localhost:3000
